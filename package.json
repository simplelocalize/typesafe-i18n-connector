{
  "name": "@simplelocalize/typesafe-i18n-connector",
  "version": "1.0.4",
  "description": "Import and export typesafe-i18n translations to/from flat JSON files compatible with SimpleLocalize",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/simplelocalize/typesafe-i18n-connector.git"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "lint": "eslint src/ && prettier --check .",
    "format": "prettier --write .",
    "prepare": "husky",
    "prepublishOnly": "npm run build"
  },
  "lint-staged": {
    "*.{ts,js}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "keywords": [
    "typesafe-i18n",
    "simplelocalize",
    "i18n",
    "translations",
    "importer",
    "exporter"
  ],
  "license": "MIT",
  "peerDependencies": {
    "typesafe-i18n": ">=5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "typesafe-i18n": "^5.26.2",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.58.2",
    "vitest": "^4.1.4"
  }
}
